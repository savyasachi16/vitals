---
import Layout from '../layouts/Layout.astro';
import HealthChart from '../components/HealthChart.tsx';
import HealthBarChart from '../components/HealthBarChart.tsx';
import HealthRangeBand from '../components/HealthRangeBand.tsx';
import HealthScatter from '../components/HealthScatter.tsx';
import HealthKpiTile from '../components/HealthKpiTile.tsx';
import HealthThresholdLine from '../components/HealthThresholdLine.tsx';
import HealthHeatmap from '../components/HealthHeatmap.tsx';
import TimeRangeSelector from '../components/TimeRangeSelector.tsx';
import WorkoutsList from '../components/WorkoutsList.tsx';
import SummaryStats from '../components/SummaryStats.tsx';

const GREEN = '#30D158';
const RED = '#FF375F';
const ORANGE = '#FF9F0A';
const BLUE = '#0A84FF';
const PURPLE = '#BF5AF2';

const audioThresholds = [
  { label: 'safe (<80 dB)', y1: 0, y2: 80, color: '#30D158' },
  { label: 'loud (80-85)', y1: 80, y2: 85, color: '#FF9F0A' },
  { label: 'damaging (>85)', y1: 85, y2: 130, color: '#FF375F' },
];

const glucoseThresholds = [
  { label: 'normal 70-140', y1: 70, y2: 140, color: '#30D158' },
];
---

<Layout title="vitals: Apple Health Dashboard">
  <main class="mx-auto max-w-6xl px-4 py-8 sm:py-10">
    <header class="mb-8">
      <h1 class="mb-2 text-4xl font-bold tracking-tight sm:text-5xl">vitals</h1>
      <p class="text-lg text-(--color-text-secondary)">Apple Health data dashboard</p>
    </header>

    <TimeRangeSelector client:load />

    <div class="mb-8">
      <SummaryStats client:load />
    </div>

    <section class="mt-8">
      <h2 class="health-section-header">Activity</h2>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <HealthBarChart client:visible metricType="HKQuantityTypeIdentifierStepCount" title="Steps" color={GREEN} />
        <HealthBarChart client:visible metricType="HKQuantityTypeIdentifierDistanceWalkingRunning" title="Distance" color={GREEN} />
        <HealthBarChart client:visible metricType="HKQuantityTypeIdentifierFlightsClimbed" title="Flights Climbed" color={GREEN} />
        <HealthBarChart client:visible metricType="HKQuantityTypeIdentifierAppleExerciseTime" title="Exercise" color={ORANGE} />
        <HealthBarChart client:visible metricType="HKQuantityTypeIdentifierAppleStandTime" title="Stand" color={ORANGE} />
        <HealthBarChart client:visible metricType="HKQuantityTypeIdentifierActiveEnergyBurned" title="Active Calories" color={ORANGE} />
        <HealthBarChart client:visible metricType="HKQuantityTypeIdentifierBasalEnergyBurned" title="Basal Calories" color={ORANGE} />
        <HealthBarChart client:visible metricType="HKQuantityTypeIdentifierPhysicalEffort" title="Physical Effort" color={ORANGE} />
      </div>
    </section>

    <section class="mt-8">
      <h2 class="health-section-header">Heart</h2>
      <div class="mb-4 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <HealthKpiTile client:visible metricType="HKQuantityTypeIdentifierRestingHeartRate" title="Resting HR" color={RED} lowerIsBetter />
        <HealthKpiTile client:visible metricType="HKQuantityTypeIdentifierHeartRateVariabilitySDNN" title="HRV (SDNN)" color={RED} />
        <HealthKpiTile client:visible metricType="HKQuantityTypeIdentifierHeartRateRecoveryOneMinute" title="HR Recovery 1m" color={RED} />
      </div>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <HealthRangeBand client:visible metricType="HKQuantityTypeIdentifierHeartRate" title="Heart Rate" color={RED} />
        <HealthChart client:visible metricType="HKQuantityTypeIdentifierWalkingHeartRateAverage" title="Walking Heart Rate" color={RED} />
        <HealthScatter client:visible metricType="HKQuantityTypeIdentifierVO2Max" title="VO2 Max" color={RED} />
      </div>
    </section>

    <section class="mt-8">
      <h2 class="health-section-header">Respiratory</h2>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <HealthRangeBand client:visible metricType="HKQuantityTypeIdentifierRespiratoryRate" title="Respiratory Rate" color={BLUE} />
        <HealthRangeBand client:visible metricType="HKQuantityTypeIdentifierOxygenSaturation" title="Blood Oxygen" color={BLUE} />
      </div>
    </section>

    <section class="mt-8">
      <h2 class="health-section-header">Body</h2>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <HealthScatter client:visible metricType="HKQuantityTypeIdentifierBodyMass" title="Weight" color={BLUE} />
        <HealthScatter client:visible metricType="HKQuantityTypeIdentifierBodyMassIndex" title="BMI" color={BLUE} />
        <HealthScatter client:visible metricType="HKQuantityTypeIdentifierBodyFatPercentage" title="Body Fat" color={BLUE} />
        <HealthScatter client:visible metricType="HKQuantityTypeIdentifierLeanBodyMass" title="Lean Mass" color={BLUE} />
        <HealthThresholdLine client:visible metricType="HKQuantityTypeIdentifierBloodGlucose" title="Blood Glucose" color={BLUE} thresholds={glucoseThresholds} />
      </div>
    </section>

    <section class="mt-8">
      <h2 class="health-section-header">Sleep</h2>
      <div class="mb-4">
        <HealthHeatmap client:visible metricType="HKCategoryTypeIdentifierSleepAnalysis" title="Sleep Calendar" color={PURPLE} unit="hr" />
      </div>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <HealthBarChart client:visible metricType="HKCategoryTypeIdentifierSleepAnalysis" title="Sleep Duration" color={PURPLE} formatter={(v: number) => {
          const m = Math.round(v * 60);
          return `${Math.floor(m / 60)}h ${m % 60}m`;
        }} unit="hr" />
        <HealthChart client:visible metricType="HKQuantityTypeIdentifierAppleSleepingWristTemperature" title="Wrist Temperature" color={PURPLE} />
        <HealthChart client:visible metricType="HKQuantityTypeIdentifierAppleSleepingBreathingDisturbances" title="Breathing Disturbances" color={PURPLE} />
      </div>
    </section>

    <section class="mt-8">
      <h2 class="health-section-header">Walking + Running</h2>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <HealthChart client:visible metricType="HKQuantityTypeIdentifierWalkingSpeed" title="Walking Speed" color={GREEN} />
        <HealthChart client:visible metricType="HKQuantityTypeIdentifierWalkingStepLength" title="Walking Step Length" color={GREEN} />
        <HealthChart client:visible metricType="HKQuantityTypeIdentifierRunningSpeed" title="Running Speed" color={ORANGE} />
        <HealthChart client:visible metricType="HKQuantityTypeIdentifierRunningPower" title="Running Power" color={ORANGE} />
        <HealthChart client:visible metricType="HKQuantityTypeIdentifierRunningStrideLength" title="Running Stride" color={ORANGE} />
        <HealthChart client:visible metricType="HKQuantityTypeIdentifierRunningGroundContactTime" title="Ground Contact Time" color={ORANGE} />
        <HealthChart client:visible metricType="HKQuantityTypeIdentifierRunningVerticalOscillation" title="Vertical Oscillation" color={ORANGE} />
      </div>
    </section>

    <section class="mt-8">
      <h2 class="health-section-header">Environment</h2>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <HealthBarChart client:visible metricType="HKQuantityTypeIdentifierTimeInDaylight" title="Time in Daylight" color={ORANGE} />
        <HealthThresholdLine client:visible metricType="HKQuantityTypeIdentifierEnvironmentalAudioExposure" title="Environmental Audio" color={BLUE} thresholds={audioThresholds} />
        <HealthThresholdLine client:visible metricType="HKQuantityTypeIdentifierHeadphoneAudioExposure" title="Headphone Audio" color={BLUE} thresholds={audioThresholds} />
        <HealthChart client:visible metricType="HKQuantityTypeIdentifierEnvironmentalSoundReduction" title="Sound Reduction" color={BLUE} />
      </div>
    </section>

    <section class="mt-8">
      <h2 class="health-section-header">Workouts</h2>
      <WorkoutsList client:visible />
    </section>
  </main>
</Layout>
