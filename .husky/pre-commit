# Block staged additions/modifications of health data. Deletions are allowed
# so we can `git rm --cached` files that were tracked before the gitignore.
PATTERN="(health\.db|export\.xml|data-.*\.json|workouts\.json|health-stats\.json)"
if git diff --cached --name-only --diff-filter=ACMR | grep -qE "$PATTERN"; then
  echo "❌ ERROR: Attempting to commit health data files!"
  git diff --cached --name-only --diff-filter=ACMR | grep -E "$PATTERN"
  echo ""
  echo "To fix: git reset HEAD -- <files>"
  exit 1
fi

echo "✅ No health data in commit"
